{
  "private": true,
  "scripts": {
    "site:serve": "python3 -m http.server 4173",
    "cf:build": "node ./scripts/build-pages.mjs",
    "cf:pages:dev": "npm run cf:build && npx wrangler pages dev dist",
    "cf:pages:deploy": "npm run cf:build && npx wrangler pages deploy dist",
    "web:dev": "next dev ./apps/web",
    "web:build": "next build ./apps/web",
    "web:start": "next start ./apps/web",
    "studio:dev": "cd apps/studio && npm run dev",
    "studio:build": "cd apps/studio && npm run build"
  },
  "dependencies": {
    "@sanity/client": "^7.14.1",
    "@sanity/image-url": "^2.0.2",
    "@shopify/storefront-api-client": "^1.0.9",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "sanity": "^5.1.0",
    "tailwindcss": "^4.1.18"
  }
}
